build --java_language_version=21
build --java_runtime_version=remotejdk_21

# RBE with BuildBuddy 

build:rbe --bes_results_url=https://app.buildbuddy.io/invocation/
build:rbe --bes_backend=grpcs://remote.buildbuddy.io
common:rbe --remote_cache=grpcs://remote.buildbuddy.io
common:rbe --noremote_upload_local_results # Uploads logs & artifacts without writing to cache
common:rbe --remote_timeout=10m
common:rbe --remote_executor=grpcs://remote.buildbuddy.io

# Note: BuildBuddy credentials stored in ~/.bazelrc
